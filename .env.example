# Environment Variables Configuration
# Copy this file to .env and update values as needed

# Training Configuration
TRAINING_TIMESTEPS=200000
REWARD_TYPE=shaped
LEARNING_RATE=0.0003
BATCH_SIZE=64
N_EPOCHS=10

# Model Configuration
MODEL_SAVE_PATH=models/ppo_model.zip
LOG_DIR=logs

# Evaluation Configuration
EVAL_EPISODES=3
EVAL_MODEL_PATH=models/ppo_shaped.zip
SAVE_GIF=false
GIF_PATH=media/agent_demo.gif

# Display Configuration (for Docker X11 forwarding on Linux)
DISPLAY=:0

# Logging Configuration
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO

# Physics Simulation Parameters (advanced)
PHYSICS_DT=0.016667
GRAVITY=9.81
CART_MASS=1.0
POLE_MASS=1.0
POLE_LENGTH=0.5
